# Copy to ".env" and adjust. Values here are safe placeholders only.

# --- Provider selection (unset CLOUDNET_PROVIDER to use rules below)
# CLOUDNET_PROVIDER=mock
# CLOUDNET_PROVIDER=aws

# Default provider when CLOUDNET_PROVIDER is unset:
# mock unless OpenStack is enabled.
OPENSTACK_ENABLED=false

# --- OpenStack (optional; set OPENSTACK_ENABLED=true when using)
# OS_AUTH_URL=http://127.0.0.1/identity/v3
# OS_USERNAME=admin
# OS_PASSWORD=changeme
# OS_PROJECT_NAME=admin
# OS_USER_DOMAIN_NAME=Default
# OS_PROJECT_DOMAIN_NAME=Default
# OS_REGION_NAME=RegionOne

# --- AWS (optional; set CLOUDNET_PROVIDER=aws)
# AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_AMI_ID=
# AWS_DEFAULT_INSTANCE_TYPE=t3.micro
# AWS_INSTANCE_PROFILE_NAME=
# AWS_ALLOW_CREATE_INSTANCES=false
# AWS_MAX_INSTANCES_PER_DEPLOY=3

# CloudNet API client (CLI / scripts)
CLOUDNET_API_BASE_URL=http://127.0.0.1:8010

# Remote exec and bundled workloads (AWS SSM). Disabled by default.
CLOUDNET_ALLOW_EXEC=false

# Access summary: when using AWS, treat SSM as available (default true).
AWS_USE_SSM=true
